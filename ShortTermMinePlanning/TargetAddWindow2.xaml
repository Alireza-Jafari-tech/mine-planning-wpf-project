<Window x:Class="ShortTermMinePlanning.TargetAddWindow2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🎯 افزودن/ویرایش هدف" 
        Height="500" Width="600"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        Background="White"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F39C12" Padding="10" Margin="0,0,0,15" CornerRadius="5">
            <TextBlock Text="🎯 اطلاعات هدف" 
                       FontSize="16" FontWeight="Bold" 
                       Foreground="White"
                       HorizontalAlignment="Center"/>
        </Border>

        <TabControl Grid.Row="1">
            <!-- Tab 1: Target -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🎯 " Margin="0,0,5,0"/>
                        <TextBlock Text="هدف ایده‌آل"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="تناژ ایده‌آل:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBox x:Name="txtIdealTonnage" Width="150" Height="35"/>
                        <ComboBox x:Name="cboIdealUnit" Width="100" Height="35" Margin="10,0,0,0"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="تن"/>
                            <ComboBoxItem Content="هزار تن"/>
                            <ComboBoxItem Content="میلیون تن"/>
                        </ComboBox>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Text="عیار ایده‌آل (%):" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtIdealGrade" Grid.Row="3" Height="35"/>
                </Grid>
            </TabItem>

            <!-- Tab 2: Tonnage Range -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📊 " Margin="0,0,5,0"/>
                        <TextBlock Text="محدوده تناژ"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="حداقل تناژ قابل قبول:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBox x:Name="txtMinTonnage" Width="150" Height="35"/>
                        <ComboBox x:Name="cboTonnageRangeUnit" Width="100" Height="35" Margin="10,0,0,0"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="تن"/>
                            <ComboBoxItem Content="هزار تن"/>
                            <ComboBoxItem Content="میلیون تن"/>
                        </ComboBox>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Text="حداکثر تناژ قابل قبول:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBox x:Name="txtMaxTonnage" Width="150" Height="35"/>
                        <ComboBox x:Name="cboTonnageRangeMaxUnit" Width="100" Height="35" Margin="10,0,0,0"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="تن"/>
                            <ComboBoxItem Content="هزار تن"/>
                            <ComboBoxItem Content="میلیون تن"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Tab 3: Grade Range -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📈 " Margin="0,0,5,0"/>
                        <TextBlock Text="محدوده عیار"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="حداقل عیار قابل قبول (%):" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtMinGrade" Grid.Row="1" Height="35" Margin="0,0,0,15"/>

                    <TextBlock Grid.Row="2" Text="حداکثر عیار قابل قبول (%):" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtMaxGrade" Grid.Row="3" Height="35"/>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button x:Name="btnSave" Click="BtnSave_Click"
                    Background="#27AE60" Foreground="White"
                    Width="100" Height="40" 
                    Margin="0,0,10,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="💾 " FontSize="14"/>
                    <TextBlock Text="ذخیره" FontSize="14"/>
                </StackPanel>
            </Button>

            <Button x:Name="btnCancel" Click="BtnCancel_Click"
                    Background="#95A5A6" Foreground="White"
                    Width="100" Height="40">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="❌ " FontSize="14"/>
                    <TextBlock Text="انصراف" FontSize="14"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>