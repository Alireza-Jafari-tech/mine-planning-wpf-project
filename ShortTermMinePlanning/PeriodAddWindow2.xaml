<Window x:Class="ShortTermMinePlanning.PeriodAddWindow2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📅 افزودن/ویرایش دوره زمانی" 
        Height="350" Width="500"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        Background="White"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#3498DB" Padding="10" Margin="0,0,0,15" CornerRadius="5">
            <TextBlock Text="📅 اطلاعات دوره زمانی" 
                       FontSize="16" FontWeight="Bold" 
                       Foreground="White"
                       HorizontalAlignment="Center"/>
        </Border>

        <StackPanel Grid.Row="1" Margin="15">
            <TextBlock Text="تاریخ شروع:" FontWeight="Bold" Margin="0,0,0,5"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <ComboBox x:Name="cboStartYear" Width="100" Height="35" Margin="0,0,10,0"/>
                <ComboBox x:Name="cboStartMonth" Width="120" Height="35" Margin="0,0,10,0"/>
                <ComboBox x:Name="cboStartDay" Width="80" Height="35"/>
            </StackPanel>

            <TextBlock Text="تاریخ پایان:" FontWeight="Bold" Margin="0,0,0,5"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <ComboBox x:Name="cboEndYear" Width="100" Height="35" Margin="0,0,10,0"/>
                <ComboBox x:Name="cboEndMonth" Width="120" Height="35" Margin="0,0,10,0"/>
                <ComboBox x:Name="cboEndDay" Width="80" Height="35"/>
            </StackPanel>

            <TextBlock Text="نمایش به صورت شمسی (سال 1400 تا 1410)" 
                       FontSize="11" Foreground="Gray"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button x:Name="btnSave" Click="BtnSave_Click"
                    Background="#27AE60" Foreground="White"
                    Width="100" Height="40" 
                    Margin="0,0,10,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="💾 " FontSize="14"/>
                    <TextBlock Text="ذخیره" FontSize="14"/>
                </StackPanel>
            </Button>

            <Button x:Name="btnCancel" Click="BtnCancel_Click"
                    Background="#95A5A6" Foreground="White"
                    Width="100" Height="40">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="❌ " FontSize="14"/>
                    <TextBlock Text="انصراف" FontSize="14"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>