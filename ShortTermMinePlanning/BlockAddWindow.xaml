<Window x:Class="ShortTermMinePlanning.BlockAddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⛏️ افزودن/ویرایش بلوک استخراج" 
        Height="550" Width="600"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        Background="White">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#27AE60" Padding="10" Margin="0,0,0,15">
            <TextBlock Text="⛏️ اطلاعات بلوک استخراج" 
                       FontSize="16" FontWeight="Bold" 
                       Foreground="White"
                       HorizontalAlignment="Center"/>
        </Border>

        <TabControl Grid.Row="1">
            <!-- Tab 1: Tonnage -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚖️ " Margin="0,0,5,0"/>
                        <TextBlock Text="تناژ"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="مقدار تناژ:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtTonnage" Grid.Row="1" 
                             Text="100"
                             Margin="0,0,0,15"
                             Height="35"/>
                    
                    <TextBlock Grid.Row="2" Text="واحد تناژ:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cboUnit" Grid.Row="3" 
                              Height="35" Margin="0,0,0,15"
                              SelectedIndex="0">
                        <ComboBoxItem Content="تن"/>
                        <ComboBoxItem Content="هزار تن"/>
                        <ComboBoxItem Content="میلیون تن"/>
                    </ComboBox>
                    
                    <TextBlock Grid.Row="4" Text="درصد استخراج از این بلوک در این دوره:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <Slider x:Name="sliderExtractionPercent" Grid.Row="5" 
                            Minimum="0" Maximum="100" Value="100"
                            TickFrequency="10" IsSnapToTickEnabled="True"
                            Margin="0,5,0,10"/>
                    <TextBlock Grid.Row="6" Text="{Binding ElementName=sliderExtractionPercent, Path=Value, StringFormat={}{0:F0}%}" 
                               HorizontalAlignment="Center" FontWeight="Bold"/>
                </Grid>
            </TabItem>

            <!-- Tab 2: Grade -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📊 " Margin="0,0,5,0"/>
                        <TextBlock Text="عیار"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="عیار ماده معدنی (%):" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtGrade" Grid.Row="1" 
                             Text="2.5"
                             Height="35"/>
                    <TextBlock Grid.Row="2" Text="مثال: عیار 2.5% به معنی 2.5 کیلوگرم در هر تن" 
                               FontSize="11" Foreground="Gray" Margin="0,5,0,0"/>
                </Grid>
            </TabItem>

            <!-- Tab 3: Cost -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💰 " Margin="0,0,5,0"/>
                        <TextBlock Text="هزینه"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="هزینه استخراج (دلار/تن):" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtExtractionCost" Grid.Row="1" 
                             Text="15"
                             Height="35"/>
                    <TextBlock Grid.Row="2" Text="شامل هزینه‌های حفاری، انفجار، بارگیری و حمل داخلی" 
                               FontSize="11" Foreground="Gray" Margin="0,5,0,0"/>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button x:Name="btnSave" Click="BtnSave_Click"
                    Background="#27AE60" Foreground="White"
                    Width="100" Height="40" 
                    Margin="0,0,10,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="💾 " FontSize="14"/>
                    <TextBlock Text="ذخیره" FontSize="14"/>
                </StackPanel>
            </Button>
            
            <Button x:Name="btnCancel" Click="BtnCancel_Click"
                    Background="#95A5A6" Foreground="White"
                    Width="100" Height="40">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="❌ " FontSize="14"/>
                    <TextBlock Text="انصراف" FontSize="14"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>