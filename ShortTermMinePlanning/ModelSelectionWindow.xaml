<Window x:Class="ShortTermMinePlanning.ModelSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="برنامه برنامه‌ریزی معدن" 
        Height="450" Width="650"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft"
        Background="White">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,30">
            <TextBlock Text="📊 برنامه برنامه‌ریزی کوتاه مدت معدن" 
                       FontSize="22" FontWeight="Bold" 
                       HorizontalAlignment="Center"
                       Foreground="#2C3E50"/>
            <TextBlock Text="انتخاب مدل برنامه‌ریزی" 
                       FontSize="14" 
                       HorizontalAlignment="Center"
                       Foreground="#7F8C8D"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Model Selection -->
        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <Border BorderBrush="#3498DB" BorderThickness="2" 
                    CornerRadius="8" Padding="15" Margin="0,5">
                <RadioButton x:Name="rbProfitModel" GroupName="ModelType" 
                             FontSize="16" Margin="0,5"
                             Checked="ModelSelectionChanged">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💰 " FontSize="18"/>
                        <TextBlock Text="مدل حداکثر سود (استخراج بهینه)" FontSize="16"/>
                    </StackPanel>
                </RadioButton>
            </Border>

            <Border BorderBrush="#95A5A6" BorderThickness="2" 
                    CornerRadius="8" Padding="15" Margin="0,5">
                <RadioButton x:Name="rbLossModel" GroupName="ModelType" 
             FontSize="16" Margin="0,10,0,10"
             Checked="ModelSelectionChanged">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠️ " FontSize="18"/>
                        <TextBlock Text="مدل حداقل ضرر (عدم تطابق تن و عیار)" FontSize="16"/>
                    </StackPanel>
                </RadioButton>
            </Border>

            <Border BorderBrush="#ECF0F1" BorderThickness="1" 
                    CornerRadius="8" Padding="10" Margin="0,10,0,0"
                    Background="#F8FAFC">
                <TextBlock x:Name="txtModelDescription" 
                           FontSize="12" 
                           Foreground="#7F8C8D"
                           TextWrapping="Wrap"
                           FontStyle="Italic"/>
            </Border>
        </StackPanel>

        <!-- Help Button -->
        <Button x:Name="btnHelp" Grid.Row="2" 
                Click="BtnHelp_Click"
                Width="120" Height="40"
                Background="#3498DB" Foreground="White"
                Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="❓ " FontSize="14" Margin="0,0,5,0"/>
                <TextBlock Text="راهنما" FontSize="14"/>
            </StackPanel>
        </Button>

        <!-- Continue Button -->
        <Button x:Name="btnContinue" Grid.Row="3" 
                Click="BtnContinue_Click"
                Width="150" Height="45"
                Background="#27AE60" Foreground="White"
                VerticalAlignment="Bottom"
                IsEnabled="False">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="▶ " FontSize="14" Margin="0,0,5,0"/>
                <TextBlock Text="ادامه به صفحه اصلی" FontSize="14" FontWeight="Bold"/>
            </StackPanel>
        </Button>
    </Grid>
</Window>