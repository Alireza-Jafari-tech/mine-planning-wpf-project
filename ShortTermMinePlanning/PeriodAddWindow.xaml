<Window x:Class="ShortTermMinePlanning.PeriodAddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📅 افزودن/ویرایش دوره زمانی" 
        Height="550" Width="600"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        Background="White"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#3498DB" Padding="10" Margin="0,0,0,15" CornerRadius="5">
            <TextBlock Text="📅 اطلاعات دوره زمانی" 
                       FontSize="16" FontWeight="Bold" 
                       Foreground="White"
                       HorizontalAlignment="Center"/>
        </Border>

        <TabControl Grid.Row="1">
            <!-- Tab 1: Date -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📆 " Margin="0,0,5,0"/>
                        <TextBlock Text="تاریخ"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="تاریخ شروع:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
                        <ComboBox x:Name="cboStartYear" Width="100" Height="35" Margin="0,0,10,0"/>
                        <ComboBox x:Name="cboStartMonth" Width="120" Height="35"/>
                        <ComboBox x:Name="cboStartDay" Width="80" Height="35"/>
                    </StackPanel>
                    
                    <TextBlock Grid.Row="2" Text="تاریخ پایان:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,15">
                        <ComboBox x:Name="cboEndYear" Width="100" Height="35" Margin="0,0,10,0"/>
                        <ComboBox x:Name="cboEndMonth" Width="120" Height="35"/>
                        <ComboBox x:Name="cboEndDay" Width="80" Height="35"/>
                    </StackPanel>
                    
                    <TextBlock Grid.Row="4" Text="نمایش به صورت شمسی (سال 1400 تا 1410)" 
                               FontSize="11" Foreground="Gray" Margin="0,5,0,0"/>
                </Grid>
            </TabItem>

            <!-- Tab 2: Capacity -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚙️ " Margin="0,0,5,0"/>
                        <TextBlock Text="ظرفیت‌ها"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="ظرفیت استخراج:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBox x:Name="txtExtractionCapacity" Width="150" Height="35"/>
                        <ComboBox x:Name="cboExtractionUnit" Width="100" Height="35" Margin="10,0,0,0"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="تن"/>
                            <ComboBoxItem Content="هزار تن"/>
                            <ComboBoxItem Content="میلیون تن"/>
                        </ComboBox>
                    </StackPanel>
                    
                    <TextBlock Grid.Row="2" Text="ظرفیت حمل:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBox x:Name="txtTransportationCapacity" Width="150" Height="35"/>
                        <ComboBox x:Name="cboTransportUnit" Width="100" Height="35" Margin="10,0,0,0"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="تن"/>
                            <ComboBoxItem Content="هزار تن"/>
                            <ComboBoxItem Content="میلیون تن"/>
                        </ComboBox>
                    </StackPanel>
                    
                    <TextBlock Grid.Row="4" Text="حداکثر بلوک‌های قابل استخراج در این دوره:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtMaxBlocks" Grid.Row="5" 
                             Height="35"
                             Tag="مثال: 10"/>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button x:Name="btnSave" Click="BtnSave_Click"
                    Background="#27AE60" Foreground="White"
                    Width="100" Height="40" 
                    Margin="0,0,10,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="💾 " FontSize="14"/>
                    <TextBlock Text="ذخیره" FontSize="14"/>
                </StackPanel>
            </Button>
            
            <Button x:Name="btnCancel" Click="BtnCancel_Click"
                    Background="#95A5A6" Foreground="White"
                    Width="100" Height="40">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="❌ " FontSize="14"/>
                    <TextBlock Text="انصراف" FontSize="14"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>