<Window x:Class="ShortTermMinePlanning.CapacityAddWindow2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⚙️ افزودن/ویرایش ظرفیت" 
        Height="450" Width="600"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        Background="White"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#9B59B6" Padding="10" Margin="0,0,0,15" CornerRadius="5">
            <TextBlock Text="⚙️ اطلاعات ظرفیت" 
                       FontSize="16" FontWeight="Bold" 
                       Foreground="White"
                       HorizontalAlignment="Center"/>
        </Border>

        <TabControl Grid.Row="1">
            <!-- Tab 1: Mine -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⛏️ " Margin="0,0,5,0"/>
                        <TextBlock Text="معدن"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="حداقل ظرفیت معدن (تن در دوره):" FontWeight="Bold" Margin="0,0,0,5"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBox x:Name="txtMineMinCapacity" Width="150" Height="35"/>
                        <ComboBox x:Name="cboMineUnit" Width="100" Height="35" Margin="10,0,0,0"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="تن"/>
                            <ComboBoxItem Content="هزار تن"/>
                            <ComboBoxItem Content="میلیون تن"/>
                        </ComboBox>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Text="حداکثر ظرفیت معدن (تن در دوره):" FontWeight="Bold" Margin="0,0,0,5"/>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBox x:Name="txtMineMaxCapacity" Width="150" Height="35"/>
                        <ComboBox x:Name="cboMineMaxUnit" Width="100" Height="35" Margin="10,0,0,0"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="تن"/>
                            <ComboBoxItem Content="هزار تن"/>
                            <ComboBoxItem Content="میلیون تن"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Tab 2: Plant -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🏭 " Margin="0,0,5,0"/>
                        <TextBlock Text="کارخانه"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="حداقل ظرفیت کارخانه (تن در دوره):" FontWeight="Bold" Margin="0,0,0,5"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBox x:Name="txtPlantMinCapacity" Width="150" Height="35"/>
                        <ComboBox x:Name="cboPlantUnit" Width="100" Height="35" Margin="10,0,0,0"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="تن"/>
                            <ComboBoxItem Content="هزار تن"/>
                            <ComboBoxItem Content="میلیون تن"/>
                        </ComboBox>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Text="حداکثر ظرفیت کارخانه (تن در دوره):" FontWeight="Bold" Margin="0,0,0,5"/>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBox x:Name="txtPlantMaxCapacity" Width="150" Height="35"/>
                        <ComboBox x:Name="cboPlantMaxUnit" Width="100" Height="35" Margin="10,0,0,0"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="تن"/>
                            <ComboBoxItem Content="هزار تن"/>
                            <ComboBoxItem Content="میلیون تن"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button x:Name="btnSave" Click="BtnSave_Click"
                    Background="#27AE60" Foreground="White"
                    Width="100" Height="40" 
                    Margin="0,0,10,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="💾 " FontSize="14"/>
                    <TextBlock Text="ذخیره" FontSize="14"/>
                </StackPanel>
            </Button>

            <Button x:Name="btnCancel" Click="BtnCancel_Click"
                    Background="#95A5A6" Foreground="White"
                    Width="100" Height="40">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="❌ " FontSize="14"/>
                    <TextBlock Text="انصراف" FontSize="14"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>