<Window x:Class="ShortTermMinePlanning.BlockAddWindow2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⛏️ افزودن/ویرایش بلوک" 
        Height="450" Width="550"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        Background="White"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#27AE60" Padding="10" Margin="0,0,0,15" CornerRadius="5">
            <TextBlock Text="⛏️ اطلاعات بلوک" 
                       FontSize="16" FontWeight="Bold" 
                       Foreground="White"
                       HorizontalAlignment="Center"/>
        </Border>

        <TabControl Grid.Row="1">
            <!-- Tab 1: Type and Tonnage -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📦 " Margin="0,0,5,0"/>
                        <TextBlock Text="نوع و تناژ"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="نوع بلوک:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
                        <RadioButton x:Name="rbOre" GroupName="BlockType" 
                                     Content="سنگ معدن" 
                                     Margin="0,0,20,0"
                                     Checked="BlockTypeChanged"/>
                        <RadioButton x:Name="rbWaste" GroupName="BlockType" 
                                     Content="باطله"
                                     Checked="BlockTypeChanged"/>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Text="مقدار تناژ:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBox x:Name="txtTonnage" Width="150" Height="35"/>
                        <ComboBox x:Name="cboUnit" Width="100" Height="35" Margin="10,0,0,0"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="تن"/>
                            <ComboBoxItem Content="هزار تن"/>
                            <ComboBoxItem Content="میلیون تن"/>
                        </ComboBox>
                    </StackPanel>

                    <TextBlock x:Name="lblGrade" Grid.Row="4" Text="عیار ماده معدنی (%):" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtGrade" Grid.Row="5" Height="35"/>
                </Grid>
            </TabItem>

            <!-- Tab 2: Extraction -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚙️ " Margin="0,0,5,0"/>
                        <TextBlock Text="استخراج"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="درصد استخراج از این بلوک در این دوره:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <Slider x:Name="sliderExtractionPercent" Grid.Row="1" 
                            Minimum="0" Maximum="100" Value="100"
                            TickFrequency="10" IsSnapToTickEnabled="True"
                            Margin="0,5,0,10"/>
                    <TextBlock Grid.Row="2" Text="{Binding ElementName=sliderExtractionPercent, Path=Value, StringFormat={}{0:F0}%}" 
                               HorizontalAlignment="Center" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock Grid.Row="3" Text="درصدی از بلوک که در این دوره استخراج می‌شود" 
                               FontSize="10" Foreground="Gray"/>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button x:Name="btnSave" Click="BtnSave_Click"
                    Background="#27AE60" Foreground="White"
                    Width="100" Height="40" 
                    Margin="0,0,10,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="💾 " FontSize="14"/>
                    <TextBlock Text="ذخیره" FontSize="14"/>
                </StackPanel>
            </Button>

            <Button x:Name="btnCancel" Click="BtnCancel_Click"
                    Background="#95A5A6" Foreground="White"
                    Width="100" Height="40">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="❌ " FontSize="14"/>
                    <TextBlock Text="انصراف" FontSize="14"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>