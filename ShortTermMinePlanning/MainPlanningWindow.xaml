<Window x:Class="ShortTermMinePlanning.MainPlanningWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📋 برنامه‌ریزی معدن" 
        Height="650" Width="1300"
        MinHeight="600" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft"
        Background="#F0F2F5"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0" Grid.ColumnSpan="5" 
                Background="#2C3E50" 
                Margin="0,0,0,8" Padding="6"
                CornerRadius="4">
            <TextBlock Text="📊 برنامه‌ریزی استخراج معدن - مدل حداکثر سود" 
                       FontSize="14" FontWeight="Bold" 
                       Foreground="White" 
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Section 1: Time Period -->
        <Border Grid.Row="1" Grid.Column="0" 
                BorderBrush="#3498DB" BorderThickness="2" 
                Margin="2" Background="White"
                CornerRadius="4">
            <StackPanel Margin="6">
                <Border Background="#3498DB" Padding="6" Margin="0,0,0,6" CornerRadius="3">
                    <TextBlock Text="📅 1. دوره زمانی" FontSize="12" FontWeight="Bold" Foreground="White"/>
                </Border>

                <Button x:Name="btnAddPeriod" Click="BtnAddPeriod_Click"
                        Background="#3498DB" Foreground="White"
                        Height="30" Margin="0,0,0,6" FontSize="11">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="➕ " FontSize="12"/>
                        <TextBlock Text="افزودن" FontSize="11"/>
                    </StackPanel>
                </Button>

                <ListBox x:Name="lstPeriods" Height="140" BorderBrush="#E2E8F0" Background="White" FontSize="11">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="4">
                                <TextBlock>
                                    <Run Text="{Binding StartDate}"/>
                                    <Run Text=" تا "/>
                                    <Run Text="{Binding EndDate}"/>
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>

        <!-- Section 2: Extraction Block -->
        <Border Grid.Row="1" Grid.Column="1" 
                BorderBrush="#27AE60" BorderThickness="2" 
                Margin="2" Background="White"
                CornerRadius="4">
            <StackPanel Margin="6">
                <Border Background="#27AE60" Padding="6" Margin="0,0,0,6" CornerRadius="3">
                    <TextBlock Text="⛏️ 2. بلوک استخراج" FontSize="12" FontWeight="Bold" Foreground="White"/>
                </Border>

                <Button x:Name="btnAddBlock" Click="BtnAddBlock_Click"
                        Background="#27AE60" Foreground="White"
                        Height="30" Margin="0,0,0,6" FontSize="11">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="➕ " FontSize="12"/>
                        <TextBlock Text="افزودن" FontSize="11"/>
                    </StackPanel>
                </Button>

                <ListBox x:Name="lstBlocks" Height="140" BorderBrush="#E2E8F0" Background="White" FontSize="11">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="4">
                                <StackPanel>
                                    <TextBlock>
                                        <Run Text="{Binding Tonnage}"/>
                                        <Run Text="{Binding TonnageUnit}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="10" Foreground="#7F8C8D">
                                        <Run Text="عیار: "/><Run Text="{Binding Grade}"/><Run Text="%"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>

        <!-- Section 3: Destination -->
        <Border Grid.Row="1" Grid.Column="2" 
                BorderBrush="#E74C3C" BorderThickness="2" 
                Margin="2" Background="White"
                CornerRadius="4">
            <StackPanel Margin="6">
                <Border Background="#E74C3C" Padding="6" Margin="0,0,0,6" CornerRadius="3">
                    <TextBlock Text="🏭 3. مقصد" FontSize="12" FontWeight="Bold" Foreground="White"/>
                </Border>

                <Button x:Name="btnAddDestination" Click="BtnAddDestination_Click"
                        Background="#E74C3C" Foreground="White"
                        Height="30" Margin="0,0,0,6" FontSize="11">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="➕ " FontSize="12"/>
                        <TextBlock Text="افزودن" FontSize="11"/>
                    </StackPanel>
                </Button>

                <ListBox x:Name="lstDestinations" Height="140" BorderBrush="#E2E8F0" Background="White" FontSize="11">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="4">
                                <StackPanel>
                                    <TextBlock>
                                        <Run Text="{Binding Price}"/><Run Text="$/تن"/>
                                    </TextBlock>
                                    <TextBlock FontSize="10" Foreground="#7F8C8D">
                                        <Run Text="فاصله: "/><Run Text="{Binding DistanceFromMine}"/><Run Text="کیلومتر"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>

        <!-- Section 4: Fleet -->
        <Border Grid.Row="1" Grid.Column="3" 
                BorderBrush="#F39C12" BorderThickness="2" 
                Margin="2" Background="White"
                CornerRadius="4">
            <StackPanel Margin="6">
                <Border Background="#F39C12" Padding="6" Margin="0,0,0,6" CornerRadius="3">
                    <TextBlock Text="🚛 4. ناوگان" FontSize="12" FontWeight="Bold" Foreground="White"/>
                </Border>

                <Button x:Name="btnAddFleet" Click="BtnAddFleet_Click"
                        Background="#F39C12" Foreground="White"
                        Height="30" Margin="0,0,0,6" FontSize="11">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="➕ " FontSize="12"/>
                        <TextBlock Text="افزودن" FontSize="11"/>
                    </StackPanel>
                </Button>

                <ListBox x:Name="lstFleets" Height="140" BorderBrush="#E2E8F0" Background="White" FontSize="11">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="4">
                                <StackPanel>
                                    <TextBlock>
                                        <Run Text="{Binding NumberOfTrucks}"/><Run Text=" دستگاه"/>
                                    </TextBlock>
                                    <TextBlock FontSize="10" Foreground="#7F8C8D">
                                        <Run Text="ظرفیت: "/><Run Text="{Binding TruckCapacity}"/><Run Text="{Binding TruckCapacityUnit}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>

        <!-- Section 5: Data Interaction -->
        <Border Grid.Row="1" Grid.Column="4" 
                BorderBrush="#9B59B6" BorderThickness="2" 
                Margin="2" Background="White"
                CornerRadius="4">
            <StackPanel Margin="6">
                <Border Background="#9B59B6" Padding="6" Margin="0,0,0,6" CornerRadius="3">
                    <TextBlock Text="📋 5. مدیریت داده‌ها" FontSize="12" FontWeight="Bold" Foreground="White"/>
                </Border>

                <WrapPanel Margin="0,0,0,6">
                    <Button x:Name="btnShowPeriods" Click="BtnShowPeriods_Click"
                            Background="#3498DB" Foreground="White"
                            Height="28" Width="55" Margin="0,0,4,4" FontSize="9">
                        <StackPanel>
                            <TextBlock Text="📅" FontSize="10" HorizontalAlignment="Center"/>
                            <TextBlock Text="دوره" FontSize="8"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnShowBlocks" Click="BtnShowBlocks_Click"
                            Background="#27AE60" Foreground="White"
                            Height="28" Width="55" Margin="0,0,4,4" FontSize="9">
                        <StackPanel>
                            <TextBlock Text="⛏️" FontSize="10" HorizontalAlignment="Center"/>
                            <TextBlock Text="بلوک" FontSize="8"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnShowDestinations" Click="BtnShowDestinations_Click"
                            Background="#E74C3C" Foreground="White"
                            Height="28" Width="55" Margin="0,0,4,4" FontSize="9">
                        <StackPanel>
                            <TextBlock Text="🏭" FontSize="10" HorizontalAlignment="Center"/>
                            <TextBlock Text="مقصد" FontSize="8"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnShowFleets" Click="BtnShowFleets_Click"
                            Background="#F39C12" Foreground="White"
                            Height="28" Width="55" Margin="0,0,4,4" FontSize="9">
                        <StackPanel>
                            <TextBlock Text="🚛" FontSize="10" HorizontalAlignment="Center"/>
                            <TextBlock Text="ناوگان" FontSize="8"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>

                <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                        Height="200" CornerRadius="3">
                    <ScrollViewer>
                        <ItemsControl x:Name="dataItemsControl" FontSize="10">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="4" Margin="0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="{Binding DisplayText}" TextWrapping="Wrap"/>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Button x:Name="btnEdit" Click="BtnEditRecord_Click"
                                                        Tag="{Binding}"
                                                        Background="#3498DB" Foreground="White"
                                                        Width="24" Height="24" Margin="0,0,2,0"
                                                        ToolTip="ویرایش" FontSize="10">
                                                    <TextBlock Text="✏️"/>
                                                </Button>

                                                <Button x:Name="btnDelete" Click="BtnDeleteRecord_Click"
                                                        Tag="{Binding}"
                                                        Background="#E74C3C" Foreground="White"
                                                        Width="24" Height="24"
                                                        ToolTip="حذف" FontSize="10">
                                                    <TextBlock Text="🗑️"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </Border>

        <!-- Bottom Buttons -->
        <StackPanel Grid.Row="2" Grid.ColumnSpan="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
            <Button x:Name="btnCalculate" Background="#27AE60" Foreground="White" Width="120" Height="35" Margin="0,0,8,0" IsEnabled="False" FontSize="12">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📊 " FontSize="12"/>
                    <TextBlock Text="محاسبه سود" FontSize="12" FontWeight="Bold"/>
                </StackPanel>
            </Button>

            <Button x:Name="btnBack" Click="BtnBack_Click" Background="#95A5A6" Foreground="White" Width="100" Height="35" FontSize="12">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔙 " FontSize="12"/>
                    <TextBlock Text="بازگشت" FontSize="12"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>